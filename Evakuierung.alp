			</ExtendsReference>
			<StartupCode><![CDATA[int i = this.getIndex();
switch (i){
	case 0:
		this.setLevel(main.level1);
		break;
	case 1:
		this.setLevel(main.level2);
		break;
	case 2:
		this.setLevel(main.level3);
		break;
	case 3:
		this.setLevel(main.level4);
		break;
	case 4:
		this.setLevel(main.level5);
		break;
	case 5:
		this.setLevel(main.level6);
		break;
}
System.out.println("Level: "+this.getLevel());]]></StartupCode>
