				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1772299973000</Id>
					<Name><![CDATA[setColor]]></Name>
					<X>360</X><Y>-60</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[switch (room_type){
	case 0:
		roomWaitingArea.setFillColor(new Color(249, 136, 136, 60));
		roomWaitingArea.setLineColor(orangeRed);
		break;
	case 1:
		roomWaitingArea.setFillColor(new Color(135, 206, 250, 60));
		roomWaitingArea.setLineColor(dodgerBlue);
		break;
	case 2:
		roomWaitingArea.setFillColor(new Color(136, 249, 136, 60));
		roomWaitingArea.setLineColor(lime);
		break;
	case 3:
		roomWaitingArea.setFillColor(new Color(182, 135, 250, 60));
		roomWaitingArea.setLineColor(purple);
		break;
}
if (!isActive)roomWaitingArea.setFillColor(new Color(193, 193, 193, 60));]]></Body>
				</Function>
			</Functions>
