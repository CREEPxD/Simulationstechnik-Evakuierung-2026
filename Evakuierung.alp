						<ActionCode><![CDATA[for (Floor_E1 f: floor_E1_6){
	for(Room r:f.rooms){
		r.releaseAll();
	}
}
for(Room r:floor_E02.rooms){
	r.releaseAll();
}
for(Room r:floor_E03.rooms){
	r.releaseAll();
}
for(Room r:floor_E04.rooms){
	r.releaseAll();
}
traceln("[Start] Starting evacuation");]]></ActionCode>
