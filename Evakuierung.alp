			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773070877143</Id>
					<Name><![CDATA[acceptPedsFromRooms]]></Name>
					<X>90</X><Y>680</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[x]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[y]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[pedStartTime]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[Pedestrian ped = add_pedestriansInFloor();
ped.set_x_pos(x);
ped.set_y_pos(y);
ped.set_startTime(pedStartTime);
pedEnterFromRoom.take(ped);]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773071789571</Id>
					<Name><![CDATA[getDistanceTo]]></Name>
					<X>100</X><Y>640</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[ped]]></Name>
						<Type><![CDATA[Pedestrian]]></Type>
					</Parameter>
					<Parameter>
						<Name><![CDATA[target]]></Name>
						<Type><![CDATA[TargetLine]]></Type>
					</Parameter>
					<Body><![CDATA[return getDistance(ped.getX(), ped.getY(), target.getX(), target.getY())]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773071986747</Id>
					<Name><![CDATA[getExit]]></Name>
					<X>240</X><Y>640</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[ped]]></Name>
						<Type><![CDATA[Pedestrian]]></Type>
					</Parameter>
					<Body><![CDATA[double dist = null;
TargetLine line = null;
for(TargetLine tar:exits){
	double distToTar = getDistanceTo(ped, tar);
	if (!dist){
		dist = distToTar;
		line = tar;
	}
	else{
		if(dist>distToTar){
			dist = distToTar;
			line = tar;
		}
	}
}
return exits.indexOf(line)+1;]]></Body>
				</Function>
			</Functions>
