			<Functions>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773419657529</Id>
					<Name><![CDATA[startEvacuation]]></Name>
					<X>430</X><Y>-40</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Body><![CDATA[for (Floor_E1 f: floor_E1_6){
	for(Room r:f.rooms){
		r.releaseAll();
	}
}
for(Room r:floor_E02.rooms){
	r.releaseAll();
}
for(Room r:floor_E03.rooms){
	r.releaseAll();
}
for(Room r:floor_E04.rooms){
	r.releaseAll();
}
traceln("[Start] Starting evacuation");]]></Body>
				</Function>
				<Function AccessType="default" StaticFunction="false">
					<ReturnModificator>VOID</ReturnModificator>
					<ReturnType><![CDATA[double]]></ReturnType>
					<Id>1773599210413</Id>
					<Name><![CDATA[logStatistics]]></Name>
					<X>430</X><Y>-10</Y>
					<Label><X>10</X><Y>0</Y></Label>
					<PublicFlag>false</PublicFlag>
					<PresentationFlag>true</PresentationFlag>
					<ShowLabel>true</ShowLabel>
					<Parameter>
						<Name><![CDATA[endTime]]></Name>
						<Type><![CDATA[double]]></Type>
					</Parameter>
					<Body><![CDATA[for (int i = 0; i<=10; i++) traceln("");
traceln("[Finished in "+String.format("%.2f", endTime)+"]");
traceln("[Floor E02]");
traceln("	- Round door: "+floor_E02.usedRoundDoor);
traceln("	- Exit IB: "+floor_E02.usedIB);
traceln("[Floor E03]");
traceln("	- IB (L): "+floor_E03.usedIBL);
traceln("	- IB (R): "+floor_E03.usedIBR);
traceln("	- ID (L): "+floor_E03.usedIDL);
traceln("	- ID (R): "+floor_E03.usedIDR);
traceln("[Floor E04]");
traceln("	- IB (L): "+floor_E04.usedIBL);
traceln("	- IB (R): "+floor_E04.usedIBR);
traceln("	- ID (L): "+floor_E04.usedIDL);
traceln("	- ID (R): "+floor_E04.usedIDR);
traceln("	- Round door: "+floor_E04.usedRound);]]></Body>
				</Function>
			</Functions>
