if (this.getIndex()!=0){
	traceln("Moving ped ["+this.getIndex()+"]:["+ped.getIndex()+"] to floor ["+(this.getIndex()-1)+"](L)");
	main.floor_E1_6.get(this.getIndex()-1).acceptPedsFromRooms(x_pos, y_pos, ped.startTime);
}
else main.floor_E02.acceptPedsFromRooms(x_pos, y_pos, ped.startTime);]]></Code>
